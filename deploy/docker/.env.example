# Machina Docker environment — copy to .env and fill in values
# NEVER commit .env to version control

# --- LLM Provider ---
# LiteLLM model identifier (e.g. openai/gpt-4o, anthropic/claude-3-5-sonnet)
MACHINA_LLM_MODEL=openai/gpt-4o
# API key for the configured LLM provider
OPENAI_API_KEY=sk-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- MCP Authentication ---
# JSON object mapping tokens to client identifiers
# Generate tokens with: openssl rand -hex 32
MACHINA_MCP_TOKENS_JSON={"your-token-here": "your-client-id"}

# --- CMMS Connection ---
# For the mock CMMS included in docker-compose:
MACHINA_CMMS_URL=http://mock-cmms:9000
MACHINA_CMMS_TYPE=generic_cmms
# For SAP PM:
# MACHINA_CMMS_URL=https://your-sap-host.example.com/sap/opu/odata/sap
# MACHINA_CMMS_TYPE=sap_pm
# MACHINA_CMMS_USERNAME=your-user
# MACHINA_CMMS_PASSWORD=your-password

# --- Sandbox Mode ---
# Set to true for safe experimentation (writes are logged, not executed)
MACHINA_SANDBOX_MODE=true

# --- Observability ---
MACHINA_LOG_LEVEL=INFO
# MACHINA_TRACE_DIR=/home/machina/traces

# --- ChromaDB (RAG vector store) ---
MACHINA_CHROMA_HOST=chromadb
MACHINA_CHROMA_PORT=8000
