# Machina systemd environment — copy to /etc/machina/machina.env
# Permissions: chmod 600 /etc/machina/machina.env
# Owner: root:machina (or root:root — systemd reads it before dropping privileges)
# NEVER commit secrets to version control

# --- LLM Provider ---
MACHINA_LLM_MODEL=openai/gpt-4o
OPENAI_API_KEY=sk-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- MCP Authentication ---
# JSON object mapping tokens to client identifiers
# Generate tokens with: openssl rand -hex 32
MACHINA_MCP_TOKENS_JSON={"your-token-here": "your-client-id"}

# --- CMMS Connection ---
MACHINA_CMMS_URL=https://your-cmms-host.example.com
MACHINA_CMMS_TYPE=sap_pm
# MACHINA_CMMS_USERNAME=your-user
# MACHINA_CMMS_PASSWORD=your-password

# --- Sandbox Mode ---
MACHINA_SANDBOX_MODE=false

# --- Observability ---
MACHINA_LOG_LEVEL=INFO
MACHINA_TRACE_DIR=/var/lib/machina/traces

# --- ChromaDB (RAG vector store, if running locally) ---
# MACHINA_CHROMA_HOST=localhost
# MACHINA_CHROMA_PORT=8000
