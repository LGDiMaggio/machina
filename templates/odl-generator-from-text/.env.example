# odl-generator-from-text — copy to .env and fill in values
# NEVER commit .env to version control

# --- LLM Provider (required) ---
# LiteLLM model identifier: openai/gpt-4o, anthropic/claude-sonnet-4-20250514, ollama/llama3
MACHINA_LLM_MODEL=openai/gpt-4o
# API key for your chosen provider
OPENAI_API_KEY=sk-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- MCP Authentication ---
# Generate tokens with: openssl rand -hex 32
MACHINA_MCP_TOKENS_JSON={"change-me-token": "template-user"}

# --- Sandbox Mode ---
# Start with true (writes are logged, not executed). Flip to false for live writes.
MACHINA_SANDBOX_MODE=true

# --- Substrate (which CMMS backend to write work orders to) ---
# "excel" (default) — writes to data/workorders.xlsx via ExcelCsvConnector
# "generic_cmms_yaml" — writes via HTTP to a CMMS using YAML schema mapping
MACHINA_SUBSTRATE=excel

# --- CMMS Connection (only needed for generic_cmms_yaml substrate) ---
MACHINA_CMMS_URL=http://mock-cmms:9000
MACHINA_CMMS_TYPE=generic_cmms

# --- Email (SMTP for sending replies) ---
MACHINA_SMTP_HOST=mock-smtp
MACHINA_SMTP_PORT=1025
MACHINA_SMTP_USERNAME=
MACHINA_SMTP_PASSWORD=
MACHINA_SMTP_FROM=machina@example.com
# IMAP for receiving inbound messages
MACHINA_IMAP_HOST=mock-smtp
MACHINA_IMAP_PORT=1143
MACHINA_EMAIL_USERNAME=machina@example.com
MACHINA_EMAIL_PASSWORD=password

# --- Telegram (optional — leave blank to disable) ---
# MACHINA_TELEGRAM_BOT_TOKEN=your-bot-token
# MACHINA_TELEGRAM_CHAT_IDS=123456789

# --- Observability ---
MACHINA_LOG_LEVEL=INFO
MACHINA_TRACE_DIR=/home/machina/traces
